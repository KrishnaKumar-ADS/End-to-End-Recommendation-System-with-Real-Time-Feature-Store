{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "DS19 — Real-Time System Health: latency, throughput, errors, cache",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "🚦 Recommendation Latency — P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(ds19_recommendation_latency_seconds_bucket[5m]))",
          "legendFormat": "P50 — {{variant}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(ds19_recommendation_latency_seconds_bucket[5m]))",
          "legendFormat": "P95 — {{variant}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(ds19_recommendation_latency_seconds_bucket[5m]))",
          "legendFormat": "P99 — {{variant}}",
          "refId": "C"
        }
      ]
    },

    {
      "id": 2,
      "title": "📨 Request Throughput (req/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(ds19_recommendation_requests_total[1m])",
          "legendFormat": "{{variant}} — {{status}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "💾 Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "ds19_cache_hit_ratio",
          "legendFormat": "Cache Hit Ratio",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "❌ HTTP 5xx Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(ds19_recommendation_requests_total{status=\"error\"}[5m]) / rate(ds19_recommendation_requests_total[5m])",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "🔬 Per-Model Inference Latency P95",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(ds19_model_inference_seconds_bucket[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    }
  ],

  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["ds19", "production", "health"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DS19 — System Health",
  "uid": "ds19-system-health",
  "version": 1
}